# ── AlalAI Docker environment — copy to .docker.env and fill in your values ──
# .docker.env is gitignored. Never commit the real file.

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Option A — MongoDB Atlas (recommended):
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/alalai_local?appName=alalai
# Option B — local Docker MongoDB (the 'mongo' service in docker-compose.yml):
# MONGODB_URI=mongodb://alalai:alalai_dev@mongo:27017/alalai_local?authSource=admin

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-32-byte-base64-string

# ── Pusher ────────────────────────────────────────────────────────────────────
PUSHER_APP_ID=your-pusher-app-id
PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=ap1
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key
NEXT_PUBLIC_PUSHER_CLUSTER=ap1

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Ollama (AI recommendations) ───────────────────────────────────────────────
OLLAMA_KEY=your-ollama-api-key

# ── Cron ──────────────────────────────────────────────────────────────────────
CRON_SECRET=replace-with-a-random-secret
